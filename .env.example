# ─── Site Configuration ───
INVENTREE_SITE_URL=https://inventree.fieldkitinfra.com
INVENTREE_DEBUG=False
INVENTREE_LOG_LEVEL=WARNING

# ─── Secret Key (generate a unique random string) ───
INVENTREE_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_STRING

# ─── Database ───
INVENTREE_DB_ENGINE=postgresql
INVENTREE_DB_NAME=inventree
INVENTREE_DB_USER=inventree
INVENTREE_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
INVENTREE_DB_HOST=inventree-db
INVENTREE_DB_PORT=5432

# ─── Cache ───
INVENTREE_CACHE_HOST=inventree-cache
INVENTREE_CACHE_PORT=6379

# ─── Admin Account (only needed on first run, remove after) ───
INVENTREE_ADMIN_USER=admin
INVENTREE_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
INVENTREE_ADMIN_EMAIL=admin@ponderosaprinting.com

# ─── Plugins ───
INVENTREE_PLUGINS_ENABLED=True
INVENTREE_PLUGIN_CHECK_ON_STARTUP=True
INVENTREE_PLUGIN_RETRY=5

# ─── Web Port ───
INVENTREE_WEB_PORT=8000
